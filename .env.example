# Copy to .env (root) and fill in values.

# External API
GOLEMIO_API_KEY=replace_me

# Redis (host apps connect via 127.0.0.1)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Realtime gateway
GATEWAY_PORT=3000
VITE_WS_URL=ws://127.0.0.1:3000/ws
VITE_API_URL=http://127.0.0.1:8000

# TimescaleDB/Postgres (host apps connect via 127.0.0.1)
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace_me
POSTGRES_HOST=127.0.0.1
POSTGRES_DB=prague_transport
POSITIONS_RETENTION_DAYS=35
POSITIONS_COMPRESS_AFTER_DAYS=2
TRAJECTORY_RETENTION_DAYS=14
TRAJECTORY_COMPRESS_AFTER_DAYS=2
PREDICTIONS_RETENTION_DAYS=7
PREDICTIONS_COMPRESS_AFTER_DAYS=1
ENABLE_TRAJECTORY_HYPERTABLE_MIGRATION=false

# PgAdmin (http://127.0.0.1:5050)
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=replace_me

# Airflow orchestration (http://127.0.0.1:8080, admin/admin by default)
# On Linux, set this to your host UID before running Airflow:
# AIRFLOW_UID=$(id -u)
AIRFLOW_UID=50000
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=replace_me
AIRFLOW_ADMIN_EMAIL=admin@example.com
URBANPULSE_FETCH_EXPORTS=false
URBANPULSE_REBUILD_LAKE=false
URBANPULSE_LAKE_INPUT_GLOB=ml/data/raw/vehicle_exports/vehicle_positions_*.csv.gz
URBANPULSE_EXPORT_DOWNLOAD_DIR=/opt/urbanpulse/ml/data/raw/vehicle_exports
URBANPULSE_CREATE_EXPORT_ARCHIVE=false
URBANPULSE_REMOTE_USER=replace_me
URBANPULSE_REMOTE_HOST=replace-me.example.com
URBANPULSE_REMOTE_DIR=/tmp/urbanpulse-vehicle-exports
URBANPULSE_REMOTE_REPO_DIR=/opt/urban-pulse
URBANPULSE_REMOTE_EXPORT_SCRIPT=export_vehicle_positions.sh
URBANPULSE_REMOTE_EXPORT_BEFORE_FETCH=true
URBANPULSE_REMOTE_INCREMENTAL_EXPORT=true
URBANPULSE_REMOTE_INCREMENTAL_MANIFEST=/opt/urbanpulse/ml/lake/vehicle_positions_manifest.json
URBANPULSE_REMOTE_INCREMENTAL_LOOKBACK_HOURS=2
URBANPULSE_REMOTE_INCREMENTAL_BOOTSTRAP_DAYS=3
URBANPULSE_REMOTE_INCREMENTAL_MAX_DAYS=3
URBANPULSE_REMOTE_EXPORT_DAYS=35
URBANPULSE_REMOTE_EXPORT_START_TS=
URBANPULSE_REMOTE_EXPORT_END_TS=
URBANPULSE_REMOTE_EXPORT_SERIES_START_TS=
URBANPULSE_REMOTE_EXPORT_SERIES_END_TS=
URBANPULSE_REMOTE_EXPORT_CHUNK_HOURS=24
URBANPULSE_REMOTE_EXPORT_SKIP_EXISTING=false
URBANPULSE_REMOTE_EXPORT_OUTPUT_DIR=/tmp/urbanpulse-vehicle-exports
URBANPULSE_REMOTE_CONTAINER_NAME=prague_db
URBANPULSE_REMOTE_DB_USER=urban
URBANPULSE_REMOTE_DB_NAME=prague_transport
URBANPULSE_REMOTE_DB_PASSWORD=replace_me
URBANPULSE_CLEAN_DOWNLOAD_DIR_BEFORE_FETCH=true
URBANPULSE_CLEAN_REMOTE_DIR_BEFORE_EXPORT=true
URBANPULSE_CLEAN_REMOTE_DIR_AFTER_FETCH=true
URBANPULSE_SSH_OPTS=-o StrictHostKeyChecking=accept-new
URBANPULSE_SCP_OPTS=-o StrictHostKeyChecking=accept-new
URBANPULSE_DUCKDB_MEMORY_LIMIT=8GB
URBANPULSE_DUCKDB_THREADS=2
URBANPULSE_FEATURE_LATEST_DATES=3
URBANPULSE_TRAIN_MAX_ROWS=1000000
URBANPULSE_TRAIN_ROW_CAP=300000
URBANPULSE_TRAIN_WINDOW_DAYS=30
URBANPULSE_TRAIN_WINDOW_END=
URBANPULSE_HOLDOUT_LAST_FILES=1
URBANPULSE_LEARNING_CURVE_ROWS=50000,150000,300000
URBANPULSE_RUN_WINDOW_COMPARISON=false
URBANPULSE_WINDOW_COMPARISON_WINDOWS=14,30,60,90,180
URBANPULSE_WINDOW_COMPARISON_REPORT=ml/reports/hgb_train_window_comparison.json
URBANPULSE_COMPARISON_LEARNING_CURVE_ROWS=
URBANPULSE_HGB_MAX_BINS=127
URBANPULSE_QUALITY_REPORT=ml/reports/data_quality_latest.json
URBANPULSE_REALTIME_EVAL_REPORT=ml/reports/realtime_delay_prediction_eval.json
URBANPULSE_REALTIME_EVAL_LOOKBACK_HOURS=24
URBANPULSE_REALTIME_EVAL_HORIZON_MINUTES=5
URBANPULSE_REALTIME_EVAL_MATCH_TOLERANCE_SECONDS=90
URBANPULSE_REALTIME_EVAL_POSITIVE_DELTA_SECONDS=60
URBANPULSE_REALTIME_EVAL_MIN_LABELED_ROWS=30
URBANPULSE_REALTIME_EVAL_MAX_PREDICTIONS=20000
URBANPULSE_REALTIME_EVAL_SCORE_SOURCE=realtime
URBANPULSE_REALTIME_EVAL_FAIL_ON_EMPTY=false
URBANPULSE_MIN_LAKE_ROWS=1000
URBANPULSE_MIN_FEATURE_ROWS=1000
URBANPULSE_MAX_ALERT_ROW_AGE_HOURS=48
URBANPULSE_FAIL_ON_ZERO_ALERTS=false

# Dashboard data-trust thresholds
PIPELINE_QUALITY_REPORT_PATH=/app/ml/reports/data_quality_latest.json
PIPELINE_REPORT_FRESHNESS_SECONDS=86400
ALERT_ARTIFACT_FRESHNESS_SECONDS=86400
ALERT_ROW_FRESHNESS_SECONDS=21600
QUALITY_WINDOW_SECONDS=900
REALTIME_DELAY_MODEL_PATH=/app/ml/models/delay_increase_hgb_5min.joblib
REALTIME_INFERENCE_ENABLED=true
REALTIME_INFERENCE_INTERVAL_SECONDS=60
REALTIME_INFERENCE_CONTEXT_MINUTES=20
REALTIME_INFERENCE_OUTPUT_FRESHNESS_SECONDS=180
REALTIME_INFERENCE_SAMPLING_SECONDS=30
REALTIME_INFERENCE_MAX_ROWS=5000
REALTIME_INFERENCE_STALE_SECONDS=180
REALTIME_ALERT_MAX_PER_RUN=25
REALTIME_ALERT_MIN_RISK=0.8
REALTIME_PREDICTION_PERSISTENCE_ENABLED=true
REALTIME_PREDICTION_MAX_PERSISTED_PER_RUN=500
REALTIME_PREDICTION_RETENTION_HOURS=72

# WandB
WANDB_API_KEY=
WANDB_PROJECT=urbanpulse
WANDB_MODE=online
WANDB_ENTITY=
WANDB_SILENT=true
